	label: string;
	kind?: 'primary' | 'secondary';
	href?: string;
	tone?: 'linkedin' | 'meaning' | 'ai' | 'growth' | 'ops';
	// Spherical coordinates (degrees) for pseudo-3D orbit.
	theta: number; // 0..360 (around)
	phi: number; // 0..180 (top->bottom)
};

const nodes: Node[] = [
	{
