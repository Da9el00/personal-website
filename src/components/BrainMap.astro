	{ id: 'lessons', label: 'Lessons', theta: 210, phi: 130 },
	{ id: 'problems', label: 'Problems', theta: 190, phi: 110 },
	{ id: 'experiments', label: 'Experiments', theta: 190, phi: 132, tone: 'ai' },
	{ id: 'growth', label: 'Growth', theta: 35, phi: 46, tone: 'growth' },
	{ id: 'management', label: 'Management', theta: 140, phi: 92, tone: 'ops' },
