---

<section
	id="brainmap"
	class="relative mt-0 left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen"
	data-step-count={steps.length}
	aria-label="Daniel’s brain map"
>
	<style>
		#brainmap-stage {
			position: absolute;
			inset: 0;
		}

		/* Minimal “smart” labels: only shown for focus + neighbors. */
		[data-node][data-show-label='1']::after,
		[data-node]:hover::after {
			content: attr(data-label);
			position: absolute;
			left: 50%;
			top: -10px;
			transform: translate(-50%, -100%);
			padding: 6px 10px;
			border-radius: 9999px;
			border: 1px solid rgba(255, 255, 255, 0.12);
			background: rgba(0, 0, 0, 0.55);
			backdrop-filter: blur(10px);
			-webkit-backdrop-filter: blur(10px);
			color: rgba(255, 255, 255, 0.86);
			font-size: 12px;
			line-height: 1;
			letter-spacing: 0.02em;
			white-space: nowrap;
			pointer-events: none;
		}

		/* Hover glow centered on the dot (so it never looks “offset”). */
		[data-node] {
			cursor: pointer !important;
			--node-glow: rgba(255, 255, 255, 0.22);
			--node-hover-border: rgba(255, 255, 255, 0.45);
			--node-hover-bg: rgba(255, 255, 255, 0.30);
			--node-hover-glow: rgba(255, 255, 255, 0.12);
		}

		/* Subtle topic tints */
		[data-node][data-tone='linkedin'] {
			--node-glow: rgba(140, 205, 255, 0.22);
			--node-hover-border: rgba(140, 205, 255, 0.55);
			--node-hover-bg: rgba(140, 205, 255, 0.18);
			--node-hover-glow: rgba(140, 205, 255, 0.14);
		}
		[data-node][data-tone='meaning'] {
			--node-glow: rgba(197, 160, 255, 0.22);
			--node-hover-border: rgba(197, 160, 255, 0.55);
			--node-hover-bg: rgba(197, 160, 255, 0.16);
			--node-hover-glow: rgba(197, 160, 255, 0.14);
		}
		[data-node][data-tone='ai'] {
			--node-glow: rgba(150, 255, 225, 0.20);
			--node-hover-border: rgba(150, 255, 225, 0.50);
			--node-hover-bg: rgba(150, 255, 225, 0.14);
			--node-hover-glow: rgba(150, 255, 225, 0.12);
		}
		[data-node][data-tone='growth'] {
			--node-glow: rgba(190, 255, 180, 0.18);
			--node-hover-border: rgba(190, 255, 180, 0.48);
			--node-hover-bg: rgba(190, 255, 180, 0.12);
			--node-hover-glow: rgba(190, 255, 180, 0.10);
		}
		[data-node][data-tone='ops'] {
			--node-glow: rgba(255, 220, 150, 0.16);
			--node-hover-border: rgba(255, 220, 150, 0.46);
			--node-hover-bg: rgba(255, 220, 150, 0.10);
			--node-hover-glow: rgba(255, 220, 150, 0.10);
		}

		[data-node]::before {
			content: '';
			position: absolute;
			inset: -14px;
			border-radius: 9999px;
			background: radial-gradient(
				circle at 50% 50%,
				var(--node-glow),
				transparent 62%
			);
			opacity: 0;
			filter: blur(0.2px);
			transition: opacity 140ms ease;
			pointer-events: none;
		}

		[data-node]:hover::before {
			opacity: 1;
		}

		[data-node]:hover {
			border-color: var(--node-hover-border) !important;
			background: var(--node-hover-bg) !important;
			box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06), 0 0 26px var(--node-hover-glow);
		}

		/* Phase card: floating narrator card (desktop), docked (mobile). */
		#brainmap-phasecard {
			position: absolute;
			left: 50%;
			top: 74%;
			transform: translate(-50%, -50%);
			width: min(440px, calc(100vw - 28px));
			pointer-events: auto;
			transition: transform 200ms cubic-bezier(0.2, 1, 0.2, 1);
		}

		@media (max-width: 900px) {
			#brainmap-phasecard {
				left: 14px;
				right: 14px;
				top: auto;
				bottom: 14px;
				width: auto;
				transform: none;
			}
		}

		/* Node click chat rail (small bubbles stacking down one side) */
		.nodeChatRail {
			position: absolute;
			top: 18%;
			bottom: 14px;
			width: min(300px, calc(100vw - 28px));
			display: flex;
			flex-direction: column;
			gap: 10px;
			pointer-events: none;
			overflow: hidden;
		}
		.nodeChatRail.left {
			left: clamp(22px, 5vw, 84px);
			align-items: flex-start;
		}
		.nodeChatRail.right {
			right: clamp(22px, 5vw, 84px);
			/* keep bubbles toward the center, not the screen edge */
			align-items: flex-start;
		}

		.nodeChatBubble {
			max-width: 100%;
			opacity: 0;
			/* Always “write in” left → right */
			--jx: 0px;
			--jy: 0px;
			transform: translateY(calc(-6px + var(--jy))) translateX(calc(-10px + var(--jx)));
			transition: opacity 160ms cubic-bezier(0.2, 1, 0.2, 1),
				transform 200ms cubic-bezier(0.2, 1, 0.2, 1);
		}
		.nodeChatBubble.in {
			opacity: 1;
			transform: translateY(var(--jy)) translateX(var(--jx));
		}
		.nodeChatBubble.out {
			opacity: 0;
			transform: translateY(calc(6px + var(--jy))) translateX(calc(8px + var(--jx)));
		}

		.nodeChatBubbleInner {
			--dx: 0px;
			--outx: 0px;
			--rot: 0deg;
			transform: translateY(-8px) translateX(var(--dx)) rotate(var(--rot));
			transition: transform 220ms cubic-bezier(0.2, 1, 0.2, 1);
		}
		.nodeChatBubble.in .nodeChatBubbleInner {
			transform: translateY(0px) translateX(var(--dx)) rotate(var(--rot));
			animation: nodeBubbleDrift 1.9s ease-in-out infinite;
		}
		.nodeChatBubble.out .nodeChatBubbleInner {
			animation: none;
			transform: translateY(-12px) translateX(var(--outx)) rotate(var(--rot));
		}

		@keyframes nodeBubbleDrift {
			0% {
				transform: translateY(0px) translateX(var(--dx)) rotate(var(--rot));
			}
			50% {
				transform: translateY(-2px) translateX(calc(var(--dx) + 6px)) rotate(var(--rot));
			}
			100% {
				transform: translateY(1px) translateX(calc(var(--dx) - 4px)) rotate(var(--rot));
			}
		}
		.nodeChatBubble .bubble {
			margin: 0;
			padding: 8px 10px;
			border-radius: 14px;
			font-size: 12px;
			line-height: 1.35;
		}

		#brainmap-chat {
			display: grid;
			gap: 10px;
			margin-top: 10px;
		}

		.bubble {
			max-width: 100%;
			border: 1px solid rgba(255, 255, 255, 0.12);
			border-radius: 16px;
			padding: 10px 12px;
			font-size: 13px;
			line-height: 1.35;
			color: rgba(255, 255, 255, 0.86);
			background: rgba(0, 0, 0, 0.42);
		}

		.bubble.ai {
			border-color: rgba(255, 255, 255, 0.14);
			background: rgba(0, 0, 0, 0.48);
		}

		.bubble.me {
			justify-self: end;
			border-color: rgba(255, 255, 255, 0.10);
			background: rgba(255, 255, 255, 0.06);
			color: rgba(255, 255, 255, 0.88);
		}

		.metaLine {
			display: flex;
			align-items: center;
			gap: 8px;
			font-size: 11px;
			color: rgba(255, 255, 255, 0.55);
			letter-spacing: 0.04em;
		}

		.stepArrow {
			height: 18px;
			width: 18px;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			border-radius: 9999px;
			border: 1px solid rgba(255, 255, 255, 0.14);
			background: rgba(255, 255, 255, 0.04);
			color: rgba(255, 255, 255, 0.70);
			line-height: 1;
			font-size: 12px;
			transform: translateZ(0);
			transition: background 140ms ease, border-color 140ms ease, color 140ms ease,
				transform 140ms ease;
			pointer-events: auto;
		}
		.stepArrow:hover {
			background: rgba(255, 255, 255, 0.08);
			border-color: rgba(255, 255, 255, 0.22);
			color: rgba(255, 255, 255, 0.9);
		}
		.stepArrow:active {
			transform: translateY(1px);
		}

		.dotPulse {
			display: inline-flex;
			gap: 4px;
			align-items: center;
		}
		.dotPulse span {
			width: 4px;
			height: 4px;
			border-radius: 9999px;
			background: rgba(255, 255, 255, 0.55);
			opacity: 0.35;
			animation: pulse 1.2s infinite;
		}
		.dotPulse span:nth-child(2) { animation-delay: 0.15s; }
		.dotPulse span:nth-child(3) { animation-delay: 0.3s; }

		@keyframes pulse {
			0%, 100% { opacity: 0.25; transform: translateY(0); }
			50% { opacity: 0.95; transform: translateY(-2px); }
		}

		.cursor {
			display: inline-block;
			width: 8px;
			height: 1.1em;
			vertical-align: text-bottom;
			border-right: 2px solid rgba(255, 255, 255, 0.75);
			margin-left: 2px;
			animation: blink 1.05s steps(1) infinite;
		}

		.bubble.typing .cursor {
			display: inline-block;
		}

		.bubble .cursor {
			display: none;
		}

		@keyframes blink {
			0%, 49% { opacity: 1; }
			50%, 100% { opacity: 0; }
		}
	</style>

	<!-- Scrolly container: sticky scene + tall scroll space -->
	<!-- Longer scroll so each slide has room. -->
	<div class="relative" style="min-height: 320vh;">
		<div class="sticky top-0 h-[100svh] w-full">
			<div
				id="brainmap-viewport"
				class="relative h-full w-full overflow-hidden"
			>
				<div id="brainmap-stage">
					<div class="pointer-events-none absolute inset-0 opacity-70">
						<div class="absolute inset-0 bg-[radial-gradient(900px_620px_at_50%_10%,rgba(255,255,255,0.07),transparent_60%)]"></div>
						<div class="absolute inset-0 bg-[radial-gradient(900px_700px_at_50%_110%,rgba(0,0,0,0.55),transparent_60%)]"></div>
					</div>

					<!-- Brain layer (reveals as the head “opens”, then zooms in) -->
					<div
						id="brainmap-brainlayer"
						class="absolute inset-0 origin-center will-change-transform"
						style="transform: translateZ(0); opacity: 0;"
					>
						<!-- Connection lines (SVG) -->
						<svg
							id="brainmap-lines"
							class="pointer-events-none absolute inset-0 h-full w-full"
							aria-hidden="true"
						>
							{edges.map((e) => (
								<line
									data-edge
									data-from={e.from}
									data-to={e.to}
									stroke="rgba(255,255,255,0.14)"
									stroke-width={e.strength === 'strong' ? 2.25 : 1.25}
									stroke-linecap="round"
									vector-effect="non-scaling-stroke"
								/>
							))}
						</svg>

						<!-- Nodes (dots; no wrapper div so DOM stays clean) -->
						{nodes.map((n) => {
							const isPrimary = n.kind === 'primary';
							const Tag = n.href ? 'a' : 'div';
							return (
								<Tag
									id={`node-${n.id}`}
									data-node
									data-node-id={n.id}
									data-label={n.label}
									data-tone={n.tone}
									data-theta={n.theta}
									data-phi={n.phi}
									href={n.href}
									target={n.href ? '_blank' : undefined}
									rel={n.href ? 'noopener noreferrer' : undefined}
									aria-label={n.label}
									title={n.label}
									class:list={[
										'absolute left-0 top-0 -translate-x-1/2 -translate-y-1/2 select-none rounded-full border backdrop-blur transition',
										'focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30',
										isPrimary
											? 'h-3.5 w-3.5 border-white/30 bg-white/35 shadow-glow'
											: 'h-2.5 w-2.5 border-white/18 bg-white/18',
										n.href ? 'cursor-pointer' : 'cursor-default',
									]}
								>
									{/* Intentionally empty: dot-only UI. */}
								</Tag>
							);
						})}
					</div>

					<!-- Node popups (AI micro-messages on click) -->
					<div id="brainmap-poplayer" class="pointer-events-none absolute inset-0 z-40">
						<div id="brainmap-nodechat-left" class="nodeChatRail left"></div>
						<div id="brainmap-nodechat-right" class="nodeChatRail right"></div>
					</div>

					<!-- Brain sticker layer (NOT inside head layer, so it never inherits head scaling) -->
					<div
						id="brainmap-brain-sticker-layer"
						class="pointer-events-none absolute left-1/2 top-[40%] z-30 -translate-x-1/2 -translate-y-1/2 will-change-transform"
					>
						<img
							id="brainmap-brain-sticker"
							class="absolute left-1/2 top-[36%] w-[clamp(170px,24vw,260px)] -translate-x-1/2 -translate-y-1/2 select-none object-contain opacity-0 [filter:drop-shadow(0_0_18px_rgba(255,255,255,0.16))_drop-shadow(0_26px_60px_rgba(0,0,0,0.75))]"
							src="/brain.png"
							alt=""
							aria-hidden="true"
							decoding="async"
						/>
					</div>

					<!-- Head layer (main centerpiece). Scroll: open + zoom into brain. -->
					<div
						id="brainmap-headlayer"
						class="pointer-events-none absolute left-1/2 top-[40%] z-20 -translate-x-1/2 -translate-y-1/2 will-change-transform"
					>
						<div class="relative">
							<div class="absolute -inset-4 rounded-[44px] bg-[conic-gradient(from_180deg_at_50%_50%,hsla(var(--accent-hue),95%,70%,0.26),transparent_28%,hsla(calc(var(--accent-hue)+90),95%,70%,0.22),transparent_64%)] blur-2xl"></div>

						<!-- Top half “lid” -->
						<img
							id="brainmap-head-top"
							class="absolute left-1/2 top-1/2 w-[clamp(220px,34vw,380px)] -translate-x-1/2 -translate-y-1/2 select-none object-contain [clip-path:polygon(0_0,100%_0,100%_48%,92%_47%,84%_49%,76%_47%,68%_49%,60%_47%,52%_49%,44%_47%,36%_49%,28%_47%,20%_49%,12%_47%,0_48%)] [filter:drop-shadow(0_26px_50px_rgba(0,0,0,0.65))]"
							src="/headshot.png"
							alt=""
							aria-hidden="true"
							decoding="async"
						/>
							<!-- Bottom half “base” -->
							<img
								id="brainmap-head-bottom"
								class="relative w-[clamp(220px,34vw,380px)] select-none object-contain [clip-path:polygon(0_48%,12%_47%,20%_49%,28%_47%,36%_49%,44%_47%,52%_49%,60%_47%,68%_49%,76%_47%,84%_49%,92%_47%,100%_48%,100%_100%,0_100%)] [filter:drop-shadow(0_26px_50px_rgba(0,0,0,0.65))]"
								src="/headshot.png"
								alt="Daniel Smidstrup"
								width="420"
								height="420"
								loading="eager"
								decoding="async"
								fetchpriority="high"
							/>
						</div>
					</div>
				</div>

				<!-- Phase card (chat narrator UI) -->
