---
import '../styles/global.css';

type Props = {
	title: string;
	description: string;
	showNav?: boolean;
};

const { title, description, showNav = false } = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, siteUrl).toString();

const ogImageUrl = new URL('/og.png', siteUrl).toString();

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Daniel Smidstrup',
	jobTitle: 'Co-founder & CTO',
	url: new URL('/', siteUrl).toString(),
	email: 'daniel@danielsmidstrup.com',
	sameAs: [
		'https://www.linkedin.com/in/daniel-smidstrup-b98390226/',
		'https://userlink.ai/',
		'https://seolint.dev/',
	],
	worksFor: {
		'@type': 'Organization',
		name: 'Userlink',
		url: 'https://userlink.ai/',
	},
	owns: {
		'@type': 'WebSite',
		name: 'SEOlint',
		url: 'https://seolint.dev/',
		description: 'Automated SEO linting tool for developers and content teams.',
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="preload" as="image" href="/headshot.png" />
		<link rel="preload" as="image" href="/brain.png" />

		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<script type="application/ld+json">{JSON.stringify(personSchema)}</script>
		<!-- Apply saved theme before paint to prevent flash — is:inline ensures this runs synchronously -->
		<script is:inline>
			(function(){
				// Light is the default. Only switch to dark if the user explicitly chose it.
				try {
					var t = localStorage.getItem('theme');
					if (t !== 'dark') {
						document.documentElement.classList.add('light');
						document.documentElement.style.background = '#f2f2f7';
					}
				} catch(e){
					document.documentElement.classList.add('light');
					document.documentElement.style.background = '#f2f2f7';
				}
			})();
		</script>
	</head>
	<body class="bg-transparent">
		{showNav && (
			<header style="position:fixed;top:0;left:0;right:0;z-index:9999;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;">
				<span id="site-nav-name" style="font-size:12px;font-weight:500;color:rgba(255,255,255,0.35);letter-spacing:0.04em;">Daniel Smidstrup</span>
				<div style="display:flex;align-items:center;gap:10px;">
					<a
						id="site-nav-freelance"
						href="/freelance"
						style="display:inline-flex;align-items:center;border-radius:9999px;border:1px solid rgba(255,255,255,0.25);background:rgba(0,0,0,0.5);padding:8px 18px;font-size:13px;font-weight:500;color:rgba(255,255,255,0.9);text-decoration:none;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);"
					>
						Freelance
					</a>
					<button id="theme-toggle" aria-label="Toggle theme" style="display:flex;height:36px;width:36px;align-items:center;justify-content:center;border-radius:9999px;border:1px solid rgba(255,255,255,0.12);background:rgba(0,0,0,0.4);color:rgba(255,255,255,0.45);cursor:pointer;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);transition:color 150ms,border-color 150ms;">
						<svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="height:14px;width:14px;">
							<path d="M7.9 1.5A6.5 6.5 0 1 0 14.5 8.1 5 5 0 0 1 7.9 1.5Z"/>
						</svg>
						<svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="height:15px;width:15px;display:none;">
							<path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6ZM8 0a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V.75A.75.75 0 0 1 8 0Zm0 13a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 8 13ZM2.343 2.343a.75.75 0 0 1 1.061 0l1.06 1.061a.75.75 0 0 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.061Zm9.193 9.193a.75.75 0 0 1 1.06 0l1.061 1.06a.75.75 0 0 1-1.06 1.061l-1.061-1.06a.75.75 0 0 1 0-1.061ZM0 8a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5H.75A.75.75 0 0 1 0 8Zm13 0a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5A.75.75 0 0 1 13 8ZM2.343 13.657a.75.75 0 0 1 0-1.061l1.06-1.06a.75.75 0 0 1 1.061 1.06l-1.06 1.061a.75.75 0 0 1-1.061 0Zm9.193-9.193a.75.75 0 0 1 0-1.06l1.06-1.061a.75.75 0 0 1 1.061 1.06l-1.06 1.061a.75.75 0 0 1-1.061 0Z"/>
						</svg>
					</button>
					<a
						id="site-nav-lock"
						href="/freelance/admin"
						aria-label="Admin"
						style="display:flex;height:36px;width:36px;align-items:center;justify-content:center;border-radius:9999px;border:1px solid rgba(255,255,255,0.12);background:rgba(0,0,0,0.4);color:rgba(255,255,255,0.25);text-decoration:none;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="height:15px;width:15px;">
							<path fill-rule="evenodd" d="M8 1a3.5 3.5 0 0 0-3.5 3.5V5H3a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-1.5v-.5A3.5 3.5 0 0 0 8 1Zm2 4v-.5a2 2 0 1 0-4 0V5h4Zm-3 4a1 1 0 1 1 2 0v1.5a.75.75 0 0 1-1.5 0V9Z" clip-rule="evenodd" />
						</svg>
					</a>
				</div>
			</header>
		)}
		{!showNav && (
			<button id="theme-toggle" aria-label="Toggle theme" style="position:fixed;top:14px;right:16px;z-index:9999;display:flex;height:34px;width:34px;align-items:center;justify-content:center;border-radius:9999px;border:1px solid var(--border);background:var(--surface);color:var(--text-3);cursor:pointer;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);transition:color 150ms,border-color 150ms;">
				<svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="height:14px;width:14px;">
					<path d="M7.9 1.5A6.5 6.5 0 1 0 14.5 8.1 5 5 0 0 1 7.9 1.5Z"/>
				</svg>
				<svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="height:15px;width:15px;display:none;">
					<path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6ZM8 0a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V.75A.75.75 0 0 1 8 0Zm0 13a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 8 13ZM2.343 2.343a.75.75 0 0 1 1.061 0l1.06 1.061a.75.75 0 0 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.061Zm9.193 9.193a.75.75 0 0 1 1.06 0l1.061 1.06a.75.75 0 0 1-1.06 1.061l-1.061-1.06a.75.75 0 0 1 0-1.061ZM0 8a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5H.75A.75.75 0 0 1 0 8Zm13 0a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5A.75.75 0 0 1 13 8ZM2.343 13.657a.75.75 0 0 1 0-1.061l1.06-1.06a.75.75 0 0 1 1.061 1.06l-1.06 1.061a.75.75 0 0 1-1.061 0Zm9.193-9.193a.75.75 0 0 1 0-1.06l1.06-1.061a.75.75 0 0 1 1.061 1.06l-1.06 1.061a.75.75 0 0 1-1.061 0Z"/>
				</svg>
			</button>
		)}
		<main class="w-full">
			<slot />
		</main>

		<script is:inline>
			function syncThemeIcons() {
				var isLight = document.documentElement.classList.contains('light');
				document.querySelectorAll('#theme-icon-moon').forEach(function(el) { el.style.display = isLight ? 'none' : 'block'; });
				document.querySelectorAll('#theme-icon-sun').forEach(function(el) { el.style.display = isLight ? 'block' : 'none'; });
			}
			syncThemeIcons();
			// Clear the inline background set by the anti-flash script — CSS variables take over now
			document.documentElement.style.removeProperty('background');

			document.querySelectorAll('#theme-toggle').forEach(function(btn) {
				btn.addEventListener('click', function() {
					// Enable transitions only for the duration of the toggle (prevents load-time flash)
					document.documentElement.classList.add('theme-transitioning');
					var isLight = document.documentElement.classList.toggle('light');
					try { localStorage.setItem('theme', isLight ? 'light' : 'dark'); } catch(e){}
					syncThemeIcons();
					setTimeout(function() { document.documentElement.classList.remove('theme-transitioning'); }, 280);
				});
			});
		</script>
	</body>
</html>

