---
import Base from '../../layouts/Base.astro';
import { supabase } from '../../lib/supabase';
import { isAdmin } from '../../lib/auth';

// Auto-redirect returning clients (skip for admins so they see the landing page)
if (!isAdmin(Astro.request)) {
	const existingCookie = Astro.request.headers.get('cookie') ?? '';
	const fkey = Object.fromEntries(
		existingCookie.split(';').map((c) => c.trim().split('=').map(decodeURIComponent))
	)['fkey'];
	if (fkey) {
		const { data } = await supabase.from('projects').select('share_key').eq('share_key', fkey).single();
		if (data) return Astro.redirect(`/freelance/view/${fkey}`);
	}
}

let keyError     = false;
let contactSent  = Astro.url.searchParams.get('sent') === '1';
let contactError = false;

if (Astro.request.method === 'POST') {
	const form   = await Astro.request.formData();
	const action = form.get('_action')?.toString();

	if (action === 'contact') {
		const name    = form.get('name')?.toString()?.trim() ?? '';
		const email   = form.get('email')?.toString()?.trim() ?? '';
		const message = form.get('message')?.toString()?.trim() ?? '';
		if (name && email) {
			const { error } = await supabase
				.from('contact_requests')
				.insert({ name, email, message: message || null });
			if (!error) return Astro.redirect('/freelance?sent=1');
		}
		contactError = true;

	} else if (action === 'project-key') {
		const key = form.get('key')?.toString()?.trim() ?? '';
		if (key) {
			const { data } = await supabase.from('projects').select('share_key').eq('share_key', key).single();
			if (data) {
				const cookie = `fkey=${key}; Path=/; SameSite=Lax; Max-Age=7776000`;
				return new Response(null, {
					status: 302,
					headers: { Location: `/freelance/view/${key}`, 'Set-Cookie': cookie },
				});
			}
		}
		keyError = true;
	}
}
---

<Base
	title="Freelance & Fractional CTO · Daniel Smidstrup"
	description="Daniel Smidstrup is available as a Fractional CTO and for selected freelance engagements · AI integration, full-stack development, and technical leadership."
>
<div class="flex min-h-screen flex-col items-center justify-center px-4 py-16">
	<div class="relative w-full max-w-[360px]" style="display:flex;flex-direction:column;gap:12px;">

		<a href="/" class="text-[13px] text-white/40 hover:text-white/70 transition" style="margin-bottom:4px;">← Daniel Smidstrup</a>

		<!-- ① Client access · top block -->
		<div class="card" style="padding:20px 24px;">
			<p class="fl-label">Existing client</p>
			<form method="POST" style="display:flex;gap:8px;margin-top:10px;">
				<input type="hidden" name="_action" value="project-key" />
				<input
					name="key"
					type="text"
					placeholder="Paste your project key…"
					autocomplete="off"
					spellcheck="false"
					required
					class="field"
					style="flex:1;"
				/>
				<button type="submit" class="btn-secondary">Open →</button>
			</form>
			{keyError && <p style="margin-top:8px;font-size:13px;color:#f87171;">Key not found · check with Daniel.</p>}
		</div>

		<!-- ② Contact form · main block -->
		<div class="card" style="padding:24px;">
			<h1 class="fl-heading">Fractional CTO &amp; Freelance</h1>
			<p class="fl-sub">Technical leadership and hands-on engineering for startups.</p>

			{contactSent ? (
				<div style="margin-top:20px;">
					<p style="font-size:14px;font-weight:500;color:#34d399;">Message sent · I'll be in touch soon.</p>
					<a href="/freelance" class="fl-link" style="display:inline-block;margin-top:10px;">Send another →</a>
				</div>
			) : (
				<form method="POST" style="display:flex;flex-direction:column;gap:10px;margin-top:20px;">
					<input type="hidden" name="_action" value="contact" />
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
						<input name="name" placeholder="Name" required class="field" />
						<input name="email" type="email" placeholder="Email" required class="field" />
					</div>
					<textarea name="message" placeholder="What are you working on?" rows="3" class="field"></textarea>
					{contactError && <p style="font-size:12px;color:#f87171;">Something went wrong · try again.</p>}
					<button type="submit" class="btn-primary" style="margin-top:4px;">Send message</button>
				</form>
			)}
		</div>

	</div>
</div>
</Base>
