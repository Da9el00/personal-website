---
import Base from '../../../layouts/Base.astro';
import { isAdmin } from '../../../lib/auth';
import { supabase } from '../../../lib/supabase';

if (!isAdmin(Astro.request)) {
	return Astro.redirect('/freelance/admin/login');
}

const { id } = Astro.params;

// ── POST handler ────────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
	const data   = await Astro.request.formData();
	const action = data.get('_action')?.toString();

	if (action === 'update-project') {
		const display_title   = data.get('display_title')?.toString()?.trim() ?? '';
		const client_name     = data.get('client_name')?.toString()?.trim() ?? '';
		const description     = data.get('description')?.toString()?.trim() ?? '';
		const offer_summary   = data.get('offer_summary')?.toString()?.trim() ?? '';
		const timeline        = data.get('timeline')?.toString()?.trim() ?? '';
		const price           = data.get('price')?.toString()?.trim() ?? '';
		const rawDeliverables = data.get('deliverables')?.toString() ?? '';
		const deliverables    = rawDeliverables.split('\n').map((l) => l.trim()).filter(Boolean);
		await supabase.from('projects').update({
			display_title: display_title || null,
			client_name:   client_name   || undefined,
			description:   description   || null,
			offer_summary: offer_summary || null,
			deliverables,
			timeline:      timeline      || null,
			price:         price         || null,
		}).eq('id', id);

	} else if (action === 'set-status') {
		const status = data.get('status')?.toString() ?? '';
		if (['offer', 'active', 'completed'].includes(status)) {
			await supabase.from('projects').update({ status }).eq('id', id);
		}

	} else if (action === 'create-label') {
		const name  = data.get('name')?.toString()?.trim() ?? '';
		const color = data.get('color')?.toString() ?? '#6b7280';
		if (name) await supabase.from('labels').insert({ project_id: id, name, color });

	} else if (action === 'delete-label') {
		const label_id = data.get('label_id')?.toString() ?? '';
		if (label_id) await supabase.from('labels').delete().eq('id', label_id);

	} else if (action === 'toggle-label') {
		const task_id  = data.get('task_id')?.toString() ?? '';
		const label_id = data.get('label_id')?.toString() ?? '';
		const assigned = data.get('assigned') === '1';
		if (task_id && label_id) {
			if (assigned) {
				await supabase.from('task_labels').delete()
					.eq('task_id', task_id).eq('label_id', label_id);
			} else {
				await supabase.from('task_labels').insert({ task_id, label_id });
			}
		}

	} else if (action === 'add-group') {
		const name = data.get('name')?.toString()?.trim() ?? '';
		if (name) await supabase.from('task_groups').insert({ project_id: id, name });

	} else if (action === 'add-task') {
		const group_id    = data.get('group_id')?.toString() ?? '';
		const title       = data.get('title')?.toString()?.trim() ?? '';
		const description = data.get('description')?.toString()?.trim() ?? '';
		if (group_id && title) {
			await supabase.from('tasks').insert({ group_id, title, description: description || null });
		}

	} else if (action === 'move-task') {
		const task_id = data.get('task_id')?.toString() ?? '';
		const status  = data.get('status')?.toString() ?? '';
		if (task_id && ['todo', 'doing', 'done'].includes(status)) {
			await supabase.from('tasks').update({ status }).eq('id', task_id);
		}

	} else if (action === 'delete-task') {
		const task_id = data.get('task_id')?.toString() ?? '';
		if (task_id) await supabase.from('tasks').delete().eq('id', task_id);

	} else if (action === 'delete-group') {
		const group_id = data.get('group_id')?.toString() ?? '';
		if (group_id) await supabase.from('task_groups').delete().eq('id', group_id);
	}

	return Astro.redirect(`/freelance/admin/${id}`);
}

// ── Fetch ────────────────────────────────────────────────────────────────────
const { data: project } = await supabase
	.from('projects').select('*').eq('id', id).single();

if (!project) return Astro.redirect('/freelance/admin');

const [{ data: rawGroups }, { data: projectLabels }] = await Promise.all([
	supabase
		.from('task_groups')
		.select('*, tasks(*, task_labels(label_id))')
		.eq('project_id', id)
		.order('created_at', { ascending: true }),
	supabase
		.from('labels')
		.select('*')
		.eq('project_id', id)
		.order('name', { ascending: true }),
]);

type Label   = { id: string; name: string; color: string };
type Task    = { id: string; title: string; description: string | null; status: 'todo' | 'doing' | 'done'; created_at: string; task_labels: { label_id: string }[] };
type Group   = { id: string; name: string; tasks: Task[] };

const labels: Label[] = projectLabels ?? [];
const labelMap = new Map(labels.map((l) => [l.id, l]));

const groups: Group[] = (rawGroups ?? []).map((g) => ({
	...g,
	tasks: (g.tasks ?? []).sort((a: Task, b: Task) =>
		new Date(a.created_at ?? 0).getTime() - new Date(b.created_at ?? 0).getTime()
	),
}));

const siteUrl  = Astro.site ?? new URL(Astro.url.origin);
const shareUrl = `${siteUrl}freelance/view/${project.share_key}`;

const statusCols: { key: Task['status']; label: string; color: string; headerColor: string }[] = [
	{ key: 'todo',  label: 'Todo',  color: 'border-white/10 bg-white/4',            headerColor: 'text-white/40'       },
	{ key: 'doing', label: 'Doing', color: 'border-amber-300/20 bg-amber-300/5',    headerColor: 'text-amber-300/70'   },
	{ key: 'done',  label: 'Done',  color: 'border-emerald-400/20 bg-emerald-400/5',headerColor: 'text-emerald-400/70' },
];

const statusMeta: Record<string, { label: string; badge: string }> = {
	offer:     { label: 'Offer',     badge: 'border-blue-400/25 bg-blue-400/8 text-blue-300/80'         },
	active:    { label: 'Active',    badge: 'border-amber-300/25 bg-amber-300/8 text-amber-300/80'      },
	completed: { label: 'Completed', badge: 'border-emerald-400/25 bg-emerald-400/8 text-emerald-400/80'},
};

const PRESET_COLORS = [
	'#f87171','#fb923c','#facc15','#4ade80',
	'#2dd4bf','#60a5fa','#c084fc','#f472b6','#94a3b8',
];

const deliverableLines = Array.isArray(project.deliverables)
	? (project.deliverables as string[]).join('\n') : '';

function nextStatus(s: Task['status']): Task['status'] | null {
	return s === 'todo' ? 'doing' : s === 'doing' ? 'done' : null;
}
function prevStatus(s: Task['status']): Task['status'] | null {
	return s === 'done' ? 'doing' : s === 'doing' ? 'todo' : null;
}
---

<Base title={`${project.display_title || project.name} — Admin`} description="Admin board">
<div class="mx-auto max-w-5xl px-4 py-10">

	<!-- ── Top nav ─────────────────────────────────────────────────────────── -->
	<div class="mb-8 flex flex-wrap items-center justify-between gap-3">
		<a href="/freelance/admin" class="text-xs text-white/30 hover:text-white/60 transition">← All projects</a>
		<div class="flex items-center gap-2 flex-wrap">
			<span class={`rounded-full border px-3 py-1 text-xs font-medium ${statusMeta[project.status ?? 'offer'].badge}`}>
				{statusMeta[project.status ?? 'offer'].label}
			</span>
			{(['offer', 'active', 'completed'] as const).filter((s) => s !== (project.status ?? 'offer')).map((s) => (
				<form method="POST" class="inline">
					<input type="hidden" name="_action" value="set-status" />
					<input type="hidden" name="status" value={s} />
					<button class="rounded-full border border-white/12 bg-white/5 px-2.5 py-1 text-[11px] text-white/40 transition hover:text-white/70">
						→ {statusMeta[s].label}
					</button>
				</form>
			))}
			<a
				href={`/freelance/view/${project.share_key}`}
				target="_blank"
				rel="noopener noreferrer"
				class="rounded-full border border-white/14 bg-white/8 px-3 py-1.5 text-xs font-medium text-white/70 transition hover:bg-white/14"
			>
				Preview as client ↗
			</a>
			<button
				id="copy-share"
				data-url={shareUrl}
				class="rounded-full border border-white/14 bg-white/8 px-3 py-1.5 text-xs font-medium text-white/70 transition hover:bg-white/14"
			>
				Copy client link
			</button>
		</div>
	</div>

	<!-- ── Project heading ─────────────────────────────────────────────────── -->
	<div class="mb-8">
		<h1 class="text-2xl font-semibold tracking-tight text-white">{project.display_title || project.name}</h1>
		{project.client_name && <p class="mt-0.5 text-sm text-white/40">Client: {project.client_name}</p>}
	</div>

	<!-- ── Offer / project details ─────────────────────────────────────────── -->
	<details class="card mb-6" {(project.status ?? 'offer') === 'offer' ? 'open' : ''}>
		<summary class="cursor-pointer select-none list-none px-5 py-4 flex items-center justify-between hover:bg-white/2 transition rounded-2xl">
			<span class="text-sm font-medium text-white/60">Project &amp; offer details</span>
			<span class="text-xs text-white/25">▾</span>
		</summary>
		<form method="POST" class="border-t border-white/[0.04] px-5 py-5 flex flex-col gap-4">
			<input type="hidden" name="_action" value="update-project" />
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
				<label class="flex flex-col gap-1.5">
					<span class="text-xs text-white/40">Client-facing title</span>
					<input name="display_title" value={project.display_title ?? ''} placeholder="e.g. AI-powered CRM for Acme"
						class="field" />
				</label>
				<label class="flex flex-col gap-1.5">
					<span class="text-xs text-white/40">Client name</span>
					<input name="client_name" value={project.client_name ?? ''} placeholder="Acme Corp"
						class="field" />
				</label>
			</div>
			<label class="flex flex-col gap-1.5">
				<span class="text-xs text-white/40">Short description</span>
				<input name="description" value={project.description ?? ''} placeholder="One-liner shown on board header"
					class="field" />
			</label>
			<label class="flex flex-col gap-1.5">
				<span class="text-xs text-white/40">Offer summary</span>
				<textarea name="offer_summary" rows={4} placeholder="Describe scope and approach…"
					class="field resize-none leading-relaxed"
				>{project.offer_summary ?? ''}</textarea>
			</label>
			<div class="flex flex-col gap-1.5">
				<span class="text-xs text-white/40">Deliverables</span>
				<!-- Hidden textarea that gets submitted — kept in sync by JS -->
				<textarea id="deliverables-hidden" name="deliverables" class="hidden">{deliverableLines}</textarea>
				<!-- Tag pill UI -->
				<div
					id="deliverables-tags"
					class="field min-h-[52px] flex flex-wrap gap-2 cursor-text"
					style="padding:10px 12px;"
					onclick="document.getElementById('deliverables-input').focus()"
				>
					{(project.deliverables as string[] ?? []).filter(Boolean).map((item: string) => (
						<span class="deliverable-tag inline-flex items-center gap-1.5 rounded-full border border-white/14 bg-white/8 pl-3 pr-2 py-1 text-xs text-white/80">
							{item}
							<button type="button" class="remove-tag flex h-4 w-4 items-center justify-center rounded-full bg-white/10 text-white/50 hover:bg-white/20 hover:text-white/90 transition text-[10px] leading-none">×</button>
						</span>
					))}
					<input
						id="deliverables-input"
						type="text"
						placeholder={((project.deliverables as string[] ?? []).length === 0) ? "Add deliverable, press Enter…" : ""}
						class="min-w-[180px] flex-1 bg-transparent text-xs text-white/80 outline-none placeholder:text-white/25"
					/>
				</div>
			</div>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
				<label class="flex flex-col gap-1.5">
					<span class="text-xs text-white/40">Timeline</span>
					<input name="timeline" value={project.timeline ?? ''} placeholder='e.g. "4–6 weeks"'
						class="field" />
				</label>
				<label class="flex flex-col gap-1.5">
					<span class="text-xs text-white/40">Price</span>
					<input name="price" value={project.price ?? ''} placeholder='e.g. "€4,500"'
						class="field" />
				</label>
			</div>
			<button type="submit" class="self-start rounded-[10px] bg-white px-4 py-2 text-sm font-semibold text-black hover:opacity-90 transition">
				Save details
			</button>
		</form>
	</details>

	<!-- ── Labels ──────────────────────────────────────────────────────────── -->
	<details class="card mb-8">
		<summary class="cursor-pointer select-none list-none px-5 py-4 flex items-center justify-between hover:bg-white/2 transition rounded-2xl">
			<div class="flex items-center gap-3">
				<span class="text-sm font-medium text-white/60">Labels</span>
				{labels.length > 0 && (
					<div class="flex items-center gap-1.5">
						{labels.map((l) => (
							<span class="h-2.5 w-2.5 rounded-full" style={`background:${l.color}`} title={l.name} />
						))}
					</div>
				)}
			</div>
			<span class="text-xs text-white/25">▾</span>
		</summary>
		<div class="border-t border-white/[0.04] px-5 py-4">

			<!-- Existing labels -->
			{labels.length > 0 && (
				<div class="mb-4 flex flex-wrap gap-2">
					{labels.map((l) => (
						<div class="flex items-center gap-1.5 rounded-full border px-2.5 py-1" style={`border-color:${l.color}40;background:${l.color}12`}>
							<span class="h-2 w-2 rounded-full shrink-0" style={`background:${l.color}`} />
							<span class="text-xs" style={`color:${l.color}`}>{l.name}</span>
							<form method="POST" class="inline" onsubmit="return confirm('Delete label?')">
								<input type="hidden" name="_action" value="delete-label" />
								<input type="hidden" name="label_id" value={l.id} />
								<button class="ml-0.5 text-[10px] leading-none opacity-40 hover:opacity-80 transition" style={`color:${l.color}`}>×</button>
							</form>
						</div>
					))}
				</div>
			)}

			<!-- Create label -->
			<form method="POST" class="flex items-center gap-2 flex-wrap">
				<input type="hidden" name="_action" value="create-label" />
				<input
					name="name"
					placeholder="Label name"
					required
					class="field w-40"
				/>
				<!-- Color swatches -->
				<div class="flex items-center gap-1.5 flex-wrap">
					{PRESET_COLORS.map((c) => (
						<label class="relative cursor-pointer">
							<input type="radio" name="color" value={c} class="peer sr-only" />
							<span
								class="block h-5 w-5 rounded-full ring-offset-1 ring-offset-black/50 peer-checked:ring-2 transition"
								style={`background:${c};--tw-ring-color:${c}`}
							/>
						</label>
					))}
					<!-- Custom color -->
					<label class="relative cursor-pointer" title="Custom color">
						<input type="radio" name="color" value="custom" class="peer sr-only" id="custom-radio" />
						<input type="color" id="custom-color-input" value="#6b7280"
							class="h-5 w-5 rounded-full cursor-pointer border-0 bg-transparent p-0 opacity-60 hover:opacity-100 transition"
							oninput="document.getElementById('custom-radio').value = this.value; document.getElementById('custom-radio').checked = true;"
						/>
					</label>
				</div>
				<button type="submit" class="rounded-[10px] bg-white px-3 py-2 text-xs font-semibold text-black hover:opacity-90 transition">
					Add label
				</button>
			</form>
			{labels.length === 0 && (
				<p class="mt-3 text-xs text-white/25">Create labels to categorize tasks — like Bug, Feature, Frontend, Blocked.</p>
			)}
		</div>
	</details>

	<!-- ── Board ───────────────────────────────────────────────────────────── -->
	<div class="mb-4 flex items-center justify-between">
		<p class="text-xs font-semibold uppercase tracking-widest text-white/30">Task Board</p>
		<span class="text-xs text-white/25">{groups.length} group{groups.length !== 1 ? 's' : ''}</span>
	</div>

	{groups.length === 0 && (
		<p class="text-center text-sm text-white/25 py-10">No task groups yet — add one below.</p>
	)}

	<div class="flex flex-col gap-8">
		{groups.map((group) => (
			<div class="card p-5">

				<div class="mb-4 flex items-center justify-between gap-3">
					<h2 class="text-sm font-semibold uppercase tracking-widest text-white/55">{group.name}</h2>
					<div class="flex items-center gap-3">
						<span class="text-xs text-white/25">{group.tasks.length} task{group.tasks.length !== 1 ? 's' : ''}</span>
						<form method="POST" onsubmit="return confirm('Delete this group and all its tasks?')">
							<input type="hidden" name="_action" value="delete-group" />
							<input type="hidden" name="group_id" value={group.id} />
							<button class="text-xs text-white/20 hover:text-red-400/60 transition">Delete</button>
						</form>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
					{statusCols.map((col) => {
						const colTasks = group.tasks.filter((t) => t.status === col.key);
						return (
							<div>
								<div class={`mb-2.5 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest ${col.headerColor}`}>
									{col.label}
									<span class="rounded-full bg-white/8 px-1.5 py-0.5 text-[10px] font-normal text-white/30">{colTasks.length}</span>
								</div>

								<div class="flex flex-col gap-2 min-h-[52px] kanban-col rounded-xl transition-colors" data-drop-col={col.key} data-group-id={group.id}>
									{colTasks.map((task) => {
										const taskLabelIds = new Set(task.task_labels?.map((tl) => tl.label_id) ?? []);
										const taskLabels   = labels.filter((l) => taskLabelIds.has(l.id));
										const unusedLabels = labels.filter((l) => !taskLabelIds.has(l.id));
										const prev = prevStatus(col.key);
										const next = nextStatus(col.key);
										return (
											<div class={`rounded-xl border p-3 ${col.color} cursor-grab active:cursor-grabbing`} draggable="true" data-task-card data-task-id={task.id}>

												<p class="text-sm text-white/85 leading-snug">{task.title}</p>
												{task.description && (
													<p class="mt-1 text-xs text-white/40 leading-snug">{task.description}</p>
												)}

												<!-- Label pills -->
												{taskLabels.length > 0 && (
													<div class="mt-2 flex flex-wrap gap-1.5">
														{taskLabels.map((l) => (
															<span
																class="inline-flex items-center gap-1 rounded-full border px-1.5 py-0.5 text-[11px] leading-none"
																style={`border-color:${l.color}40;background:${l.color}15;color:${l.color}`}
															>
																<span class="h-1.5 w-1.5 rounded-full" style={`background:${l.color}`} />
																{l.name}
															</span>
														))}
													</div>
												)}

												<!-- Actions row -->
												<div class="mt-2.5 flex items-center gap-1.5 flex-wrap">
													{prev && (
														<form method="POST" class="inline">
															<input type="hidden" name="_action" value="move-task" />
															<input type="hidden" name="task_id" value={task.id} />
															<input type="hidden" name="status" value={prev} />
															<button class="text-[11px] text-white/30 hover:text-white/70 transition">
																← {prev.charAt(0).toUpperCase() + prev.slice(1)}
															</button>
														</form>
													)}
													{prev && next && <span class="text-white/15 text-[10px]">·</span>}
													{next && (
														<form method="POST" class="inline">
															<input type="hidden" name="_action" value="move-task" />
															<input type="hidden" name="task_id" value={task.id} />
															<input type="hidden" name="status" value={next} />
															<button class="text-[11px] text-white/30 hover:text-white/70 transition">
																{next.charAt(0).toUpperCase() + next.slice(1)} →
															</button>
														</form>
													)}

													<!-- Label toggle dropdown -->
													{labels.length > 0 && (
														<details class="relative ml-auto">
															<summary class="cursor-pointer select-none list-none text-[11px] text-white/25 hover:text-white/60 transition">
																label
															</summary>
															<div class="absolute right-0 top-5 z-20 min-w-[140px] rounded-xl border border-white/12 bg-[#0d1117] p-2 shadow-xl flex flex-col gap-0.5">
																{taskLabels.map((l) => (
																	<form method="POST">
																		<input type="hidden" name="_action" value="toggle-label" />
																		<input type="hidden" name="task_id" value={task.id} />
																		<input type="hidden" name="label_id" value={l.id} />
																		<input type="hidden" name="assigned" value="1" />
																		<button class="w-full flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs text-left hover:bg-white/6 transition">
																			<span class="h-2 w-2 rounded-full shrink-0" style={`background:${l.color}`} />
																			<span style={`color:${l.color}`}>{l.name}</span>
																			<span class="ml-auto text-white/30">✓</span>
																		</button>
																	</form>
																))}
																{unusedLabels.map((l) => (
																	<form method="POST">
																		<input type="hidden" name="_action" value="toggle-label" />
																		<input type="hidden" name="task_id" value={task.id} />
																		<input type="hidden" name="label_id" value={l.id} />
																		<input type="hidden" name="assigned" value="0" />
																		<button class="w-full flex items-center gap-2 rounded-lg px-2 py-1.5 text-xs text-left hover:bg-white/6 transition">
																			<span class="h-2 w-2 rounded-full shrink-0 opacity-40" style={`background:${l.color}`} />
																			<span class="text-white/50">{l.name}</span>
																		</button>
																	</form>
																))}
															</div>
														</details>
													)}

													<form method="POST" class="inline" onsubmit="return confirm('Delete task?')">
														<input type="hidden" name="_action" value="delete-task" />
														<input type="hidden" name="task_id" value={task.id} />
														<button class="text-[11px] text-white/20 hover:text-red-400/60 transition">×</button>
													</form>
												</div>

											</div>
										);
									})}
								</div>
							</div>
						);
					})}
				</div>

				<!-- Add task -->
				<details class="mt-4 border-t border-white/[0.04] pt-4">
					<summary class="cursor-pointer select-none list-none text-xs text-white/30 hover:text-white/60 transition">
						+ Add task
					</summary>
					<form method="POST" class="mt-3 flex flex-col gap-2">
						<input type="hidden" name="_action" value="add-task" />
						<input type="hidden" name="group_id" value={group.id} />
						<input name="title" placeholder="Task title" required
							class="field" />
						<input name="description" placeholder="Short note (optional)"
							class="field" />
						<button type="submit" class="self-start rounded-[8px] bg-white px-3 py-1.5 text-xs font-semibold text-black hover:opacity-90 transition">
							Add task
						</button>
					</form>
				</details>

			</div>
		))}
	</div>

	<!-- Add group -->
	<div class="mt-8 card p-5">
		<p class="mb-3 text-xs font-semibold uppercase tracking-widest text-white/30">Add task group</p>
		<form method="POST" class="flex gap-3">
			<input type="hidden" name="_action" value="add-group" />
			<input name="name" placeholder='e.g. "Daily Tasks" · "AI Integration" · "Azure" · "Frontend"' required
				class="field flex-1" />
			<button type="submit" class="rounded-[10px] bg-white px-4 py-2.5 text-sm font-semibold text-black hover:opacity-90 transition whitespace-nowrap">
				Add group
			</button>
		</form>
	</div>

</div>

<!-- Hidden form used by drag-and-drop -->
<form id="dnd-form" method="POST" style="display:none">
	<input type="hidden" name="_action" value="move-task" />
	<input id="dnd-task-id" type="hidden" name="task_id" value="" />
	<input id="dnd-status" type="hidden" name="status" value="" />
</form>

<style>
	.kanban-col.drag-over {
		background: rgba(255,255,255,0.04);
		outline: 1.5px dashed rgba(255,255,255,0.18);
	}
</style>

<script>
	// ── Deliverables tag input ────────────────────────────────────────────────
	const tagsEl   = document.getElementById('deliverables-tags')!;
	const inputEl  = document.getElementById('deliverables-input') as HTMLInputElement;
	const hiddenEl = document.getElementById('deliverables-hidden') as HTMLTextAreaElement;

	function syncHidden() {
		const tags = Array.from(tagsEl.querySelectorAll<HTMLElement>('.deliverable-tag'))
			.map((t) => t.childNodes[0].textContent?.trim() ?? '').filter(Boolean);
		hiddenEl.value = tags.join('\n');
		inputEl.placeholder = tags.length === 0 ? 'Add deliverable, press Enter…' : '';
	}

	function addTag(value: string) {
		const text = value.trim();
		if (!text) return;
		const span = document.createElement('span');
		span.className = 'deliverable-tag inline-flex items-center gap-1.5 rounded-full border border-white/14 bg-white/8 pl-3 pr-2 py-1 text-xs text-white/80';
		span.innerHTML = `${text}<button type="button" class="remove-tag flex h-4 w-4 items-center justify-center rounded-full bg-white/10 text-white/50 hover:bg-white/20 hover:text-white/90 transition text-[10px] leading-none">×</button>`;
		tagsEl.insertBefore(span, inputEl);
		inputEl.value = '';
		syncHidden();
	}

	inputEl.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') {
			e.preventDefault();
			addTag(inputEl.value);
		} else if (e.key === 'Backspace' && inputEl.value === '') {
			const last = tagsEl.querySelector<HTMLElement>('.deliverable-tag:last-of-type');
			last?.remove();
			syncHidden();
		}
	});

	tagsEl.addEventListener('click', (e) => {
		const btn = (e.target as HTMLElement).closest('.remove-tag');
		if (btn) { btn.closest('.deliverable-tag')?.remove(); syncHidden(); }
	});

	// ── Copy share link ───────────────────────────────────────────────────────
	const btn = document.getElementById('copy-share');
	btn?.addEventListener('click', () => {
		const url = (btn as HTMLElement).dataset.url ?? '';
		navigator.clipboard.writeText(url).then(() => {
			btn.textContent = 'Copied!';
			setTimeout(() => { btn.textContent = 'Copy client link'; }, 1800);
		});
	});

	// ── Kanban drag-and-drop ──────────────────────────────────────────────────
	let draggingId: string | null = null;

	document.querySelectorAll<HTMLElement>('[data-task-card]').forEach((card) => {
		card.addEventListener('dragstart', (e) => {
			draggingId = card.dataset.taskId ?? null;
			setTimeout(() => { card.style.opacity = '0.35'; }, 0);
			(e as DragEvent).dataTransfer!.effectAllowed = 'move';
		});
		card.addEventListener('dragend', () => {
			card.style.opacity = '';
			document.querySelectorAll<HTMLElement>('.kanban-col').forEach((col) => col.classList.remove('drag-over'));
		});
	});

	document.querySelectorAll<HTMLElement>('.kanban-col').forEach((col) => {
		col.addEventListener('dragover', (e) => {
			e.preventDefault();
			(e as DragEvent).dataTransfer!.dropEffect = 'move';
			col.classList.add('drag-over');
		});
		col.addEventListener('dragleave', (e) => {
			if (!col.contains((e as MouseEvent).relatedTarget as Node)) {
				col.classList.remove('drag-over');
			}
		});
		col.addEventListener('drop', (e) => {
			e.preventDefault();
			col.classList.remove('drag-over');
			if (!draggingId) return;
			const status = col.dataset.dropCol ?? '';
			if (!status) return;
			(document.getElementById('dnd-task-id') as HTMLInputElement).value = draggingId;
			(document.getElementById('dnd-status') as HTMLInputElement).value = status;
			(document.getElementById('dnd-form') as HTMLFormElement).submit();
		});
	});
</script>
</Base>
