---
import Base from '../../../layouts/Base.astro';
import { isAdmin, clearAdminCookie } from '../../../lib/auth';
import { supabase } from '../../../lib/supabase';

if (!isAdmin(Astro.request)) {
	return Astro.redirect('/freelance/admin/login');
}

if (Astro.request.method === 'POST') {
	const data   = await Astro.request.formData();
	const action = data.get('_action')?.toString();

	if (action === 'create') {
		const name        = data.get('name')?.toString()?.trim() ?? '';
		const client_name = data.get('client_name')?.toString()?.trim() ?? '';
		const description = data.get('description')?.toString()?.trim() ?? '';
		if (name && client_name) {
			await supabase.from('projects').insert({ name, client_name, description });
		}
	} else if (action === 'delete') {
		const id = data.get('id')?.toString() ?? '';
		if (id) await supabase.from('projects').delete().eq('id', id);
	} else if (action === 'mark-read') {
		const id = data.get('id')?.toString() ?? '';
		if (id) await supabase.from('contact_requests').update({ read: true }).eq('id', id);
	} else if (action === 'delete-request') {
		const id = data.get('id')?.toString() ?? '';
		if (id) await supabase.from('contact_requests').delete().eq('id', id);
	} else if (action === 'logout') {
		return new Response(null, {
			status: 302,
			headers: { Location: '/freelance/admin/login', 'Set-Cookie': clearAdminCookie() },
		});
	}

	return Astro.redirect('/freelance/admin');
}

const [{ data: projects }, { data: requests }] = await Promise.all([
	supabase
		.from('projects')
		.select('*')
		.order('created_at', { ascending: false }),
	supabase
		.from('contact_requests')
		.select('*')
		.order('created_at', { ascending: false }),
]);

const unread = (requests ?? []).filter((r) => !r.read).length;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);

function timeAgo(iso: string): string {
	const diff = Date.now() - new Date(iso).getTime();
	const m = Math.floor(diff / 60000);
	if (m < 1)   return 'just now';
	if (m < 60)  return `${m}m ago`;
	const h = Math.floor(m / 60);
	if (h < 24)  return `${h}h ago`;
	const d = Math.floor(h / 24);
	return `${d}d ago`;
}
---

<Base title="Freelance Admin — Daniel Smidstrup" description="Admin dashboard">
<div class="mx-auto max-w-3xl px-4 py-12">

	<!-- Header -->
	<div class="mb-8 flex items-center justify-between">
		<div>
			<p class="text-xs font-medium uppercase tracking-widest text-white/50">Admin Portal</p>
			<h1 class="mt-1 text-2xl font-semibold tracking-tight text-white">Dashboard</h1>
		</div>
		<form method="POST">
			<input type="hidden" name="_action" value="logout" />
			<button class="rounded-full border border-white/12 bg-white/5 px-3 py-1.5 text-xs text-white/50 transition hover:text-white/80">
				Sign out
			</button>
		</form>
	</div>

	<!-- ── Incoming requests ───────────────────────────────────────────────── -->
	<div class="mb-10">
		<div class="mb-3 flex items-center gap-3">
			<p class="text-xs font-semibold uppercase tracking-widest text-white/55">Incoming requests</p>
			{unread > 0 && (
				<span class="rounded-full bg-white/90 px-2 py-0.5 text-[11px] font-semibold text-black">
					{unread} new
				</span>
			)}
		</div>

		{!requests?.length && (
			<p class="text-sm text-white/40 py-6 text-center">No requests yet.</p>
		)}

		<div class="flex flex-col gap-3">
			{requests?.map((r) => (
				<div class={`card px-5 py-4 ${!r.read ? 'border-white/18' : 'border-white/8'}`}>
					<div class="flex items-start justify-between gap-4">
						<div class="min-w-0 flex-1">
							<div class="flex items-center gap-2 flex-wrap">
								{!r.read && (
									<span class="h-1.5 w-1.5 rounded-full bg-white/70 shrink-0" />
								)}
								<span class={`text-sm font-medium ${r.read ? 'text-white/55' : 'text-white/90'}`}>
									{r.name}
								</span>
								<a
									href={`mailto:${r.email}`}
									class="text-xs text-white/50 hover:text-white/60 transition truncate"
								>
									{r.email}
								</a>
								<span class="text-xs text-white/35 ml-auto shrink-0">{timeAgo(r.created_at)}</span>
							</div>
							{r.message && (
								<p class="mt-2 text-sm text-white/50 leading-relaxed">{r.message}</p>
							)}
						</div>
					</div>
					<div class="mt-3 flex items-center gap-2">
						<a
							href={`mailto:${r.email}`}
							class="rounded-full border border-white/12 bg-white/5 px-3 py-1 text-xs text-white/50 transition hover:text-white/80"
						>
							Reply
						</a>
						{!r.read && (
							<form method="POST" class="inline">
								<input type="hidden" name="_action" value="mark-read" />
								<input type="hidden" name="id" value={r.id} />
								<button class="rounded-full border border-white/10 bg-white/4 px-3 py-1 text-xs text-white/50 transition hover:text-white/60">
									Mark read
								</button>
							</form>
						)}
						<form method="POST" class="inline ml-auto" onsubmit="return confirm('Delete this request?')">
							<input type="hidden" name="_action" value="delete-request" />
							<input type="hidden" name="id" value={r.id} />
							<button class="text-xs text-white/35 hover:text-red-400/60 transition">Delete</button>
						</form>
					</div>
				</div>
			))}
		</div>
	</div>

	<!-- ── Projects ───────────────────────────────────────────────────────── -->
	<div class="mb-3 flex items-center gap-3">
		<p class="text-xs font-semibold uppercase tracking-widest text-white/55">Projects</p>
	</div>

	<details class="card mb-6">
		<summary class="cursor-pointer px-5 py-4 text-sm font-medium text-white/60 hover:text-white/80 transition select-none list-none flex items-center gap-2">
			<span class="text-white/40">+</span> New project
		</summary>
		<form method="POST" class="border-t border-white/[0.04] px-5 py-4 flex flex-col gap-3">
			<input type="hidden" name="_action" value="create" />
			<input name="name" placeholder="Project name (internal)" required
				class="field" />
			<input name="client_name" placeholder="Client name" required
				class="field" />
			<textarea name="description" placeholder="Short description (optional)" rows="2"
				class="field resize-none"></textarea>
			<button type="submit"
				class="self-start rounded-[10px] bg-white px-4 py-2 text-sm font-semibold text-black transition hover:opacity-90">
				Create project
			</button>
		</form>
	</details>

	{!projects?.length && (
		<p class="text-sm text-white/40 text-center py-8">No projects yet.</p>
	)}

	<div class="flex flex-col gap-3">
		{projects?.map((p) => (
			<div class="card flex items-center gap-4 px-5 py-4">
				<div class="flex-1 min-w-0">
					<p class="text-sm font-medium text-white/90 truncate">{p.display_title || p.name}</p>
					<p class="text-xs text-white/50 mt-0.5">{p.client_name}{p.description ? ` — ${p.description}` : ''}</p>
				</div>
				<div class="flex items-center gap-2 shrink-0 flex-wrap">
					<button
						data-share-url={`${siteUrl}freelance/view/${p.share_key}`}
						onclick="navigator.clipboard.writeText(this.dataset.shareUrl).then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Share link'},1500)})"
						class="rounded-full border border-white/12 bg-white/5 px-3 py-1.5 text-xs text-white/50 transition hover:text-white/80"
					>
						Share link
					</button>
					<a href={`/freelance/admin/${p.id}`}
						class="rounded-full border border-white/14 bg-white/8 px-3 py-1.5 text-xs font-medium text-white/80 transition hover:bg-white/14">
						Open board →
					</a>
					<form method="POST" onsubmit="return confirm('Delete this project and all its tasks?')">
						<input type="hidden" name="_action" value="delete" />
						<input type="hidden" name="id" value={p.id} />
						<button class="rounded-full border border-red-500/20 bg-red-500/5 px-3 py-1.5 text-xs text-red-400/55 transition hover:text-red-400/90">
							Delete
						</button>
					</form>
				</div>
			</div>
		))}
	</div>

</div>
</Base>
