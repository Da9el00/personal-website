---
import Base from '../layouts/Base.astro';
---

<Base
	title="Not found — Daniel Smidstrup"
	description="The page you were looking for doesn't exist."
>
<div class="flex min-h-screen flex-col items-center justify-center px-4 py-16">
	<div class="w-full max-w-[420px] text-center">

		<p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/35">404</p>

		<h1 class="mt-3 text-3xl font-semibold tracking-tight text-white leading-tight">
			Page not found
		</h1>

		<p class="mt-3 text-sm text-white/55 leading-relaxed">
			The link is broken or the page has moved. Try one of these instead.
		</p>

		<div class="mt-8 flex flex-col gap-2.5">
			<a
				href="/freelance"
				class="inline-flex items-center justify-center rounded-[10px] bg-white px-4 py-2.5 text-sm font-semibold text-black transition hover:opacity-90"
			>
				Freelance & Fractional CTO →
			</a>
			<a
				href="/"
				class="inline-flex items-center justify-center rounded-[10px] border border-white/12 bg-white/5 px-4 py-2.5 text-sm font-medium text-white/70 transition hover:bg-white/10"
			>
				← Daniel Smidstrup
			</a>
		</div>

	</div>
</div>
</Base>
